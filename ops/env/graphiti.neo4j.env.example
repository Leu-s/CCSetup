# Copy to: ops/env/graphiti.neo4j.env
# Default localhost bind keeps the stack reachable only from this machine unless you widen GRAPHITI_BIND_HOST.
OPENAI_API_KEY=
GOOGLE_API_KEY=
NEO4J_USER=neo4j
NEO4J_PASSWORD=demodemo
GRAPHITI_BIND_HOST=127.0.0.1
GRAPHITI_MCP_CONFIG_PATH=/graphiti-config/config-docker-neo4j.openai.yaml
GRAPHITI_TELEMETRY_ENABLED=false
SEMAPHORE_LIMIT=4
GRAPHITI_GIT_REF=mcp-v1.0.2
