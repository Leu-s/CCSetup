# Copy to: ~/.claude/graphiti.falkordb.env (chmod 600).
# Docker Compose loads this path via ${HOME}/.claude/graphiti.falkordb.env with required=false.
# FalkorDB remains a local-only profile. Keep SEMAPHORE_LIMIT=1 unless you have measured a safe alternative.
OPENAI_API_KEY=
GOOGLE_API_KEY=
GRAPHITI_BIND_HOST=127.0.0.1
GRAPHITI_MCP_CONFIG_PATH=/graphiti-config/config-docker-falkordb.openai.yaml
GRAPHITI_TELEMETRY_ENABLED=false
SEMAPHORE_LIMIT=1
GRAPHITI_GIT_REF=mcp-v1.0.2
